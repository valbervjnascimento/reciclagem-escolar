rules_version = '2';

// Regras de segurança do Firestore para o EcoGestão Escolar.
//
// Como aplicar:
//   1. Instale a Firebase CLI: npm install -g firebase-tools
//   2. firebase login
//   3. firebase init firestore   (aponte para este arquivo)
//   4. firebase deploy --only firestore:rules
//
// Ideia geral:
//   - Qualquer usuário logado pode LER os dados (necessário para o painel
//     e para o admin montarem listas de alunos/turmas).
//   - Só o próprio professor (dono da turma) pode criar/editar/excluir os
//     dados da sua turma, alunos e registros.
//   - O e-mail listado em isAdmin() tem acesso total (mesmo papel do
//     ADMIN_EMAILS usado no código).
//
// Ajuste a lista de e-mails administradores conforme necessário.

service cloud.firestore {
  match /databases/{database}/documents {

    function estaLogado() {
      return request.auth != null;
    }

    function isAdmin() {
      return estaLogado() &&
        request.auth.token.email in [
          'valbervjnascimento@gmail.com'
        ];
    }

    function ehDonoDoRecurso(professorId) {
      return estaLogado() && request.auth.uid == professorId;
    }

    match /professores/{professorId} {
      allow read: if estaLogado();
      allow create: if ehDonoDoRecurso(professorId);
      allow update, delete: if ehDonoDoRecurso(professorId) || isAdmin();
    }

    match /turmas/{turmaId} {
      allow read: if estaLogado();
      allow create: if estaLogado() && request.resource.data.professorId == request.auth.uid;
      allow update, delete: if isAdmin() ||
        (estaLogado() && resource.data.professorId == request.auth.uid);
    }

    match /alunos/{alunoId} {
      allow read: if estaLogado();
      allow create, update: if estaLogado();
      allow delete: if estaLogado() || isAdmin();
    }

    match /registros/{registroId} {
      allow read: if estaLogado();
      allow create: if estaLogado() && request.resource.data.professorId == request.auth.uid;
      allow update, delete: if isAdmin() ||
        (estaLogado() && resource.data.professorId == request.auth.uid);
    }
  }
}
